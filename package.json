{
  "name": "arctic-code",
  "productName": "Arctic Code",
  "version": "2.0.0-beta.2",
  "buildNumber": "25427.01",
  "description": "Arctic Code Beta 2 - AI Coding Agent by Orange Studio",
  "author": "Orange Studio",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n vite,electron \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "vite build && electron-builder --publish never",
    "dist:mac": "vite build && electron-builder --mac --publish never",
    "dist:linux": "vite build && electron-builder --linux --publish never",
    "dist:win": "vite build && electron-builder --win --publish never",
    "dist:all": "vite build && electron-builder -mwl --publish never"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.orangestudio.arcticcode",
    "productName": "Arctic Code",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    }
  }
}
